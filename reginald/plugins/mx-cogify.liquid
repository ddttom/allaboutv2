{% comment %}
  MX Cogify for Shopify
  Paste this into: Online Store > Themes > Edit Code > theme.liquid (before </head>)
  Or add as a Custom Liquid section via the theme customiser.
{% endcomment %}

<!-- MX Cogify: MX Carrier Tags -->
<meta name="mx:status" content="active">
<meta name="mx:content-policy" content="extract-with-attribution">
<meta name="mx:audience" content="{{ page.template_suffix | default: 'humans' }}">

{% if template contains 'product' %}
  <meta name="mx:contentType" content="product">
{% elsif template contains 'article' or template contains 'blog' %}
  <meta name="mx:contentType" content="blog-post">
{% elsif template contains 'collection' %}
  <meta name="mx:contentType" content="landing-page">
{% elsif template contains 'page' %}
  <meta name="mx:contentType" content="article">
{% else %}
  <meta name="mx:contentType" content="page">
{% endif %}

{% if product.tags.size > 0 %}
  <meta name="mx:tags" content="{{ product.tags | join: ', ' }}">
{% elsif article.tags.size > 0 %}
  <meta name="mx:tags" content="{{ article.tags | join: ', ' }}">
{% endif %}

<!-- MX Cogify: Discovery -->
<link rel="llms-txt" href="/pages/llms-txt">

<!-- MX Cogify: Schema.org JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  {% if template contains 'product' %}
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 200 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "image": "{{ product.featured_image | image_url: width: 1200 }}",
  {% if product.selected_or_first_available_variant.price %}
  "offers": {
    "@type": "Offer",
    "price": "{{ product.selected_or_first_available_variant.price | money_without_currency }}",
    "priceCurrency": "{{ shop.currency }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}"
  },
  {% endif %}
  {% elsif template contains 'article' %}
  "@type": "BlogPosting",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt_or_content | strip_html | truncate: 200 | json }},
  "url": "{{ shop.url }}{{ article.url }}",
  "datePublished": "{{ article.published_at | date: '%Y-%m-%d' }}",
  "dateModified": "{{ article.updated_at | default: article.published_at | date: '%Y-%m-%d' }}",
  {% if article.image %}
  "image": "{{ article.image | image_url: width: 1200 }}",
  {% endif %}
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  {% else %}
  "@type": "WebPage",
  "name": {{ page_title | json }},
  "description": {{ page_description | json }},
  "url": "{{ canonical_url }}",
  {% endif %}
  "inLanguage": "{{ request.locale.iso_code | default: 'en' }}",
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}"
  }
}
</script>
